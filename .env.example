# ── App ───────────────────────────────────────────────────────────────────────
APP_URL="https://your-app.vercel.app"

# ── Firebase (client-side — read bookings from Firestore) ────────────────────
VITE_FIREBASE_API_KEY="your-firebase-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
VITE_FIREBASE_APP_ID="your-app-id"

# ── Firebase Admin (server-side — webhook updates Firestore) ─────────────────
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'

# ── Zeepay (get these after merchant account approval) ───────────────────────
ZEEPAY_MERCHANT_ID="your-zeepay-merchant-id"
ZEEPAY_API_KEY="your-zeepay-api-key"

# ── Webhook Security ──────────────────────────────────────────────────────────
WEBHOOK_SECRET="your-random-secret-here"
